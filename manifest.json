{
  "manifest_version": 3,
  "name": "Firefox YouTube Video Translator",
  "version": "1.0",
  "description": "Translates YouTube subtitles into your preferred language in real-time.",
  "permissions": [
    "activeTab"
  ],
  "host_permissions": [
    "https://translate.googleapis.com/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
