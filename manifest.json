{
  "manifest_version": 3,
  "name": "Universal Video Subtitle Translator",
  "version": "1.1",
  "description": "Translates subtitles on YouTube and other HTML5 video players in real-time.",
  "permissions": [
    "activeTab"
  ],
  "host_permissions": [
    "https://translate.googleapis.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
